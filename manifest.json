{
  "manifest_version": 3,
  "name": "Catify Everything",
  "version": "1.0",
  "description": "Replace all images with random cats.",
  "permissions": [],
  "host_permissions": [
    "https://api.thecatapi.com/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}